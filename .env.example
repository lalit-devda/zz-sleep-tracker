# Required --dart-define values for zz-sleep-tracker
#
# Never commit actual values. Supply them at build time:
#   flutter run  -d chrome --dart-define=FIREBASE_API_KEY=...
#   flutter build web --dart-define=FIREBASE_API_KEY=...
#
# ── OAuth2 Grant Type ──────────────────────────────────────────────────────────
# This app uses the Firebase "Resource Owner Password" OAuth2 grant:
#   User email + password → Firebase ID Token (RS256 JWT, Bearer)
#   → DartStreamClient.onboardFirebaseSession() → DartStream tenant session
# The FIREBASE_API_KEY is the OAuth2 client_id that identifies this web
# application to the Firebase / DartStream SaaS identity layer.
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Firebase project Web API key (OAuth2 client credential / client_id)
# Obtain from: Firebase Console → Project Settings → General → Web API Key
FIREBASE_API_KEY=

# [OPTIONAL] Override the DartStream API base URL (leave blank for default dev)
DARTSTREAM_BASE_URL=
